# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5437

# Server
UNIFIED_PORT=3010

# Authentication (REQUIRED in production)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Optional: Auto-create admin user on first start
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password

# Database URL
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5437/app

# RAG Module — LLM provider (anthropic | scaleway | ollama)
LLM_PROVIDER=anthropic
# RAG Module — Embedding provider (openai | scaleway)
EMBEDDING_PROVIDER=openai

# Anthropic (LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI embeddings (EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key

# Scaleway — OpenAI-compatible, supports OpenAI + Mistral models (LLM_PROVIDER=scaleway or EMBEDDING_PROVIDER=scaleway)
# SCALEWAY_API_KEY=your-scaleway-api-key
# SCALEWAY_BASE_URL=https://api.scaleway.ai/v1
# SCALEWAY_LLM_MODEL=llama-3.1-70b-instruct
# SCALEWAY_EMBEDDING_MODEL=bge-multilingual-gemma2

# Ollama — local models (LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_LLM_MODEL=llama3.2
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Optional: Confluence indexing (RAG module)
# CONFLUENCE_BASE_URL=https://your-company.atlassian.net
# JIRA_EMAIL=your-email@company.com
# JIRA_API_TOKEN=your-jira-api-token
